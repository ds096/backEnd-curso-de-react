generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Post {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Task {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  description String
  completed Boolean
  title       String
}
